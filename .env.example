# ─── Core ──────────────────────────────────────────────────────────────────
NEXTAUTH_URL=https://www.odudoc.com
NEXTAUTH_SECRET=                       # openssl rand -base64 32
DATABASE_URL=                          # Neon pooled connection string

# ─── Super-admin / ops ────────────────────────────────────────────────────
SUPER_ADMIN_EMAILS=                    # comma-separated; admin@odudoc.com is always included
MAINTENANCE_MODE=                      # set to "1" to return 503 on tenant routes
CSRF_TRUSTED_ORIGINS=                  # comma-separated extra origins (default: NEXTAUTH_URL)

# ─── Cron ─────────────────────────────────────────────────────────────────
CRON_SECRET=                           # Bearer token required by /api/cron/*

# ─── Stripe ───────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=                     # sk_live_...
STRIPE_WEBHOOK_SECRET=                 # whsec_... for /api/webhooks/stripe
STRIPE_PRICE_MAP=                      # "price_abc:starter,price_def:growth,price_ghi:scale"

# ─── Email (Resend) ───────────────────────────────────────────────────────
RESEND_API_KEY=
RESEND_WEBHOOK_SECRET=                 # whsec_... from Resend dashboard
RESEND_FROM_NOREPLY=no-reply@odudoc.com
RESEND_FROM_NOTIFICATIONS=notifications@odudoc.com
RESEND_FROM_PROMOTION=promotions@odudoc.com

# ─── SMS / Voice / WhatsApp (Twilio) ──────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=                     # also used for webhook signature verify
TWILIO_MESSAGING_SERVICE_SID=
TWILIO_WHATSAPP_FROM=                  # "whatsapp:+14155238886"
TWILIO_VOICE_FROM=
TWILIO_WA_OTP_CONTENT_SID=             # HX... — login OTP template
TWILIO_WA_APPT_REMINDER_CONTENT_SID=   # HX... — appointment reminder template
TWILIO_WA_PRESCRIPTION_CONTENT_SID=    # HX... — prescription delivered template

# ─── WhatsApp Cloud API direct (Meta) ─────────────────────────────────────
# Preferred provider — no BSP markup. Falls back to sent.dm > Twilio
# when these are unset. Get the token + phone-number-id from the
# Meta App Dashboard → WhatsApp → API Setup page.
WHATSAPP_CLOUD_API_TOKEN=              # permanent access token
WHATSAPP_PHONE_NUMBER_ID=              # numeric ID Meta assigns
WHATSAPP_WEBHOOK_VERIFY_TOKEN=         # any string; echo'd back during webhook setup
META_WA_LOCALE=en                      # template locale, e.g. "en" or "en_US"
META_WA_TEMPLATE_LOGIN_OTP=            # HSM name for login OTP
META_WA_TEMPLATE_APPT_REMINDER=        # HSM name for appointment reminder
META_WA_TEMPLATE_PRESCRIPTION_READY=   # HSM name for prescription ready
# Note: request-otp accepts either SENTDM_TEMPLATE_OTP (canonical name
# used by lib/sent-dm + lib/otp-store) or the legacy
# SENTDM_TEMPLATE_LOGIN_OTP. Use the same name everywhere.
# Set to "1" to enable Gemini-backed post-visit Q&A on inbound WA replies.
# Off by default so deployments without GEMINI_API_KEY stay deterministic.
WA_AI_POST_VISIT_ENABLED=0

# ─── Rate limiting (Upstash) ──────────────────────────────────────────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ─── Observability (Sentry) ──────────────────────────────────────────────
SENTRY_DSN=
SENTRY_ENVIRONMENT=production

# ─── Video (Daily.co) ─────────────────────────────────────────────────────
DAILY_API_KEY=
DAILY_DOMAIN=                          # e.g. odudoc.daily.co

# ─── Blob storage (Vercel) ────────────────────────────────────────────────
BLOB_READ_WRITE_TOKEN=

# ─── AI (for blog generator, analyze) ─────────────────────────────────────
ANTHROPIC_API_KEY=

# ─── Webhook endpoints to configure in provider dashboards ────────────────
#   Stripe:  https://www.odudoc.com/api/webhooks/stripe
#   Resend:  https://www.odudoc.com/api/webhooks/resend
#   Twilio:  https://www.odudoc.com/api/webhooks/twilio/status  (status callback)
