{
  "ci": {
    "collect": {
      "url": [
        "https://www.odudoc.com/",
        "https://www.odudoc.com/consult",
        "https://www.odudoc.com/blog",
        "https://www.odudoc.com/contact",
        "https://www.odudoc.com/corporate",
        "https://www.odudoc.com/about",
        "https://www.odudoc.com/privacy"
      ],
      "numberOfRuns": 3,
      "settings": {
        "preset": "desktop",
        "skipAudits": ["uses-rel-preconnect"]
      }
    },
    "assert": {
      "assertions": {
        "categories:performance": ["warn", { "minScore": 0.7 }],
        "categories:accessibility": ["error", { "minScore": 0.85 }],
        "categories:best-practices": ["warn", { "minScore": 0.85 }],
        "categories:seo": ["warn", { "minScore": 0.85 }],
        "first-contentful-paint": ["warn", { "maxNumericValue": 2000 }],
        "largest-contentful-paint": ["warn", { "maxNumericValue": 3000 }],
        "cumulative-layout-shift": ["warn", { "maxNumericValue": 0.15 }]
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
