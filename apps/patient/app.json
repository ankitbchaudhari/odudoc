{
  "expo": {
    "name": "OduDoc",
    "slug": "odudoc-patient",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./src/assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "odudoc",
    "splash": {
      "image": "./src/assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#020617"
    },
    "ios": {
      "bundleIdentifier": "com.odudoc.patient",
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "Scan QR codes on medicine packaging to verify authenticity.",
        "NSPhotoLibraryUsageDescription": "Attach photos to your prescriptions.",
        "NSHealthShareUsageDescription": "Sync vitals from Apple Health to your medical record.",
        "NSHealthUpdateUsageDescription": "Write vital readings back to Apple Health."
      }
    },
    "android": {
      "package": "com.odudoc.patient",
      "adaptiveIcon": {
        "foregroundImage": "./src/assets/adaptive-icon.png",
        "backgroundColor": "#020617"
      },
      "permissions": ["CAMERA", "ACCESS_FINE_LOCATION", "POST_NOTIFICATIONS"]
    },
    "plugins": [
      "expo-secure-store"
    ],
    "extra": {
      "eas": {
        "projectId": "REPLACE_WITH_YOUR_EAS_PROJECT_ID"
      }
    }
  }
}
