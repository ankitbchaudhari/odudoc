# /opt/odudoc-files/.env  —  COPY THIS TO .env ON THE VPS AND FILL IN VALUES
# Generate strong random values:
#   openssl rand -hex 32
#
# The SAME FILES_API_KEY value must be set on Vercel as FILES_API_KEY.
# FILES_SIGNING_SECRET is VPS-only (never leaves the server).

FILES_API_KEY=replace_with_openssl_rand_hex_32
FILES_SIGNING_SECRET=replace_with_a_DIFFERENT_openssl_rand_hex_32
FILES_STORAGE_ROOT=/var/www/files
FILES_PUBLIC_BASE_URL=https://files.odudoc.com
PORT=3000
